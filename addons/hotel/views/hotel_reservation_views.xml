<?xml version="1.0" encoding="UTF-8" ?>

<odoo>

    <!--    Vista Árbol-->
    <record id="view_hotel_reservation_tree" model="ir.ui.view">
        <field name="name">hotel.reservation.tree</field>
        <field name="model">hotel.reservation</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="guest_id"/>
                <field name="room_id"/>
                <field name="check_in"/>
                <field name="check_out"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <!--    Vista Formulario-->
    <record id="view_hotel_reservation_form" model="ir.ui.view">
        <field name="name">hotel.reservation.form</field>
        <field name="model">hotel.reservation</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Información General">
                            <field name="name"/>
                            <field name="state"/>
                            <field name="guest_id"/>
                            <field name="room_id"/>
                        </group>

                        <group string="Fechas">
                            <field name="check_in"/>
                            <field name="check_out"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notas">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!--    Acción-->
    <record id="action_hotel_reservation" model="ir.actions.act_window">
        <field name="name">Reservas</field>
        <field name="res_model">hotel.reservation</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!--    Menú-->
    <menuitem
            id="menu_hotel_reservation"
            name="Reservas"
            parent="menu_hotel_root"
            action="action_hotel_reservation"
            sequence="30"
    />

</odoo>