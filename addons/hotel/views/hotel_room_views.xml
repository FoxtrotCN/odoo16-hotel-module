<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <!--    Vista Árbol-->
    <record id="view_hotel_room_tree" model="ir.ui.view">

        <field name="name">hotel.room.tree</field>
        <field name="model">hotel.room</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="room_type"/>
                <field name="capacity"/>
                <field name="price_per_night"/>
                <field name="state"/>
            </tree>
        </field>

    </record>

    <!--    Vista Formulario-->
    <record id="view_hotel_room_form" model="ir.ui.view">

        <field name="name">hotel.room.form</field>
        <field name="model">hotel.room</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Información General">
                            <field name="name"/>
                            <field name="room_type"/>
                            <field name="capacity"/>
                            <field name="state"/>
                        </group>

                        <group string="Precios">
                            <field name="price_per_night"/>
                            <field name="floor"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Comodidades">
                            <field name="amenity_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="description"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Reservas">
                            <field name="reservation_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="guest_id"/>
                                    <field name="check_in"/>
                                    <field name="check_out"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Notas">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>

    </record>

    <!--    Vista de búsqueda-->
    <record id="view_hotel_room_search" model="ir.ui.view">
        <field name="name">hotel.room.search</field>
        <field name="model">hotel.room</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="room_type"/>
                <filter
                        name="available"
                        string="Disponibles"
                        domain="[('state', '=', 'available')]"
                />
                <filter
                        name="occupied"
                        string="Ocupadas"
                        domain="[('state', '=', 'occupied')]"
                />
                <filter
                        name="maintenance"
                        string="Mantenimiento"
                        domain="[('state', '=', 'maintenance')]"
                />
                <group expand="0" string="Agrupar por">
                    <filter
                            name="group_by_type"
                            string="Tipo"
                            context="{'group_by': 'room_type'}"
                    />
                </group>
            </search>
        </field>
    </record>

    <!--    Acción de ventana-->
    <record id="action_hotel_room" model="ir.actions.act_window">
        <field name="name">Habitaciones</field>
        <field name="res_model">hotel.room</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_hotel_room_search"/>
    </record>

    <!--    Menú raíz-->
    <menuitem
            id="menu_hotel_root"
            name="Hotel"
            sequence="10"
    />

    <!--    Submenú de habitaciones-->
    <menuitem
            id="menu_hotel_room"
            name="Habitaciones"
            parent="menu_hotel_root"
            action="action_hotel_room"
            sequence="10"
    />


</odoo>